{
  "builds": [
    {
      "src": "wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "handle": "filesystem"
    },
    {
      "src": "/favicon.ico",
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ]
}
